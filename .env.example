# Vorlage für die .env (echte Datei NICHT einchecken, Mode 600).
# Der Backend-Code liest diese Variablen; API-Keys nur als Fallback,
# wenn in config.json (Webinterface) kein Key gesetzt ist.

# --- Erst-Admin (beim ersten Start angelegt) ---
ADMIN_USER=admin
ADMIN_PASSWORD=bitte-aendern

# --- Lizenz (Produkt RAGW) ---
# Produkt-Secret aus dem Lizenz Admin. Ohne korrektes Secret koennen
# Lizenzschluessel nicht verifiziert werden (App laeuft dann nur im Trial).
RAG_LICENSE_SECRET=

# --- Lokale LLM-Engine (Ollama) ---
# Erreichbare Ollama-URL des Zielservers; leer lassen, wenn nur Cloud genutzt wird.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Cloud-LLM-Keys (optional) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
